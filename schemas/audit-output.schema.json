{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GaboITB/mcp-shield/schemas/audit-output.schema.json",
  "title": "MCP Shield Audit Output",
  "description": "JSON Schema for MCP Shield audit result output. Validate with: python -m mcp_shield validate report.json",
  "type": "object",
  "required": ["name", "source", "findings", "total_score", "grade", "timestamp"],
  "properties": {
    "name": {
      "type": "string",
      "description": "MCP server name"
    },
    "source": {
      "type": "string",
      "description": "Source path, URL, or npm package name"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of the audit"
    },
    "total_score": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of all finding weights"
    },
    "grade": {
      "type": "string",
      "enum": ["A+", "A", "B", "C", "D", "F"],
      "description": "Overall audit grade"
    },
    "critical_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of critical findings"
    },
    "high_count": {
      "type": "integer",
      "minimum": 0,
      "description": "Number of high findings"
    },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/Finding" },
      "description": "List of security findings"
    },
    "tools_static": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolInfo" },
      "description": "Tools extracted from static analysis"
    },
    "tools_live": {
      "type": "array",
      "items": { "$ref": "#/$defs/ToolInfo" },
      "description": "Tools fetched from live MCP connection"
    },
    "resources": {
      "type": "array",
      "items": { "$ref": "#/$defs/ResourceInfo" },
      "description": "MCP resources fetched from live connection"
    },
    "prompts": {
      "type": "array",
      "items": { "$ref": "#/$defs/PromptInfo" },
      "description": "MCP prompts fetched from live connection"
    },
    "capabilities": {
      "oneOf": [
        { "$ref": "#/$defs/ServerCapabilities" },
        { "type": "null" }
      ],
      "description": "Server declared capabilities"
    },
    "health": {
      "type": "object",
      "description": "Repository health indicators"
    },
    "deps": {
      "type": "object",
      "description": "Dependency analysis results"
    },
    "urls": {
      "type": "array",
      "items": { "type": "object" },
      "description": "Extracted and classified URLs"
    },
    "pinned_version": {
      "type": "object",
      "description": "Version pinning information"
    },
    "aivss": {
      "oneOf": [
        { "$ref": "#/$defs/AIVSSResult" },
        { "type": "null" }
      ],
      "description": "AIVSS vulnerability score"
    },
    "deny_rules": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Suggested deny rules for destructive tools"
    },
    "sbom": {
      "type": "object",
      "description": "CycloneDX-compatible SBOM"
    },
    "deprecated_msg": { "type": "string" },
    "sdk_info": { "type": "object" },
    "dep_audit": { "type": "string" },
    "transitive_audit": { "type": "string" },
    "npm_github_diff": { "type": "object" },
    "rate_limited_tools": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "Finding": {
      "type": "object",
      "required": ["rule_id", "severity", "surface", "title", "evidence", "location"],
      "properties": {
        "rule_id": {
          "type": "string",
          "description": "Unique rule identifier (e.g., shell_injection, prompt_injection)"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low", "info"],
          "description": "Finding severity level"
        },
        "surface": {
          "type": "string",
          "enum": ["source_code", "mcp_metadata", "runtime_delta"],
          "description": "Detection surface where the finding was discovered"
        },
        "title": {
          "type": "string",
          "description": "Human-readable finding title"
        },
        "evidence": {
          "type": "string",
          "description": "Evidence snippet (code, pattern match, etc.)"
        },
        "location": {
          "type": "string",
          "description": "Location: file:line, tool_name, or endpoint"
        },
        "detail": {
          "type": "string",
          "description": "Detailed explanation of the finding"
        }
      }
    },
    "ToolInfo": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "input_schema": { "type": "object" },
        "output_schema": { "type": "object" },
        "annotations": { "type": "object" },
        "source": { "type": "string", "enum": ["static", "live", ""] },
        "file": { "type": "string" },
        "line": { "type": "integer", "minimum": 0 }
      }
    },
    "ResourceInfo": {
      "type": "object",
      "required": ["uri"],
      "properties": {
        "uri": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "mime_type": { "type": "string" }
      }
    },
    "PromptInfo": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "arguments": {
          "type": "array",
          "items": { "type": "object" }
        }
      }
    },
    "ServerCapabilities": {
      "type": "object",
      "properties": {
        "tools": { "type": "boolean" },
        "resources": { "type": "boolean" },
        "prompts": { "type": "boolean" },
        "sampling": { "type": "boolean" },
        "logging": { "type": "boolean" }
      }
    },
    "AIVSSResult": {
      "type": "object",
      "properties": {
        "score": { "type": "number", "minimum": 0, "maximum": 10 },
        "vector": { "type": "string" },
        "breakdown": { "type": "object" }
      }
    }
  }
}
